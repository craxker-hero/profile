.woswidgets-marker-circle { position: relative; text-align: center; user-select: none; height: 1em; min-width: 1em; padding-left: 0.05em; padding-right: 0.05em; box-sizing: border-box; display: inline-block; vertical-align: middle; top: -0.11em; line-height: 0; }

.woswidgets-marker-circle::before { content: ""; position: absolute; inset: -10%; border-radius: 1em; }

.woswidgets-marker-circle svg { width: 1.125em; height: 1.125em; }

.woswidgets-marker-content { position: relative; display: inline-block; vertical-align: middle; font-size: calc(.8em * var(--marker-font-size-adjust, 1)); font-weight: var(--marker-font-weight, bold); line-height: 1; transform: translateY(-50%); top: 50%; pointer-events: none; }

