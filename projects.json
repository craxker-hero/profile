    "title": "DashFlow CRM",
    "tagline": "De 3 hojas de Excel a una sola interfaz con estado global.",
    "why": "El cliente gestionaba leads en 3 hojas de Excel distintas. Reemplacé esa fricción con queries optimizadas y un único estado centralizado. El reto real fue el optimistic update: la UI no podía esperar al servidor.",
    "emoji": "⚡",
    "image": null,
    "tags": [
      { "label": "React",      "color": "green"  },
      { "label": "Node.js",    "color": "cyan"   },
      { "label": "PostgreSQL", "color": "pink"   }
    ],
    "snippet": {
      "lang": "JavaScript",
      "lines": [
        { "type": "comment", "text": "// Hook: optimistic update sin bloquear la UI" },
        { "type": "kw",      "text": "const " },
        { "type": "fn",      "text": "useOptimisticLeads" },
        { "type": "plain",   "text": " = () => {" },
        { "type": "plain",   "text": "  const [leads, setLeads] = useState([]);" },
        { "type": "plain",   "text": "" },
        { "type": "kw",      "text": "  const " },
        { "type": "fn",      "text": "updateLead" },
        { "type": "plain",   "text": " = async (id, patch) => {" },
        { "type": "comment", "text": "    // Actualiza UI de inmediato" },
        { "type": "plain",   "text": "    setLeads(prev => prev.map(l =>" },
        { "type": "plain",   "text": "      l.id === id ? { ...l, ...patch } : l" },
        { "type": "plain",   "text": "    ));" },
        { "type": "kw",      "text": "    try " },
        { "type": "plain",   "text": "{ await api.patch(`/leads/${id}`, patch); }" },
        { "type": "kw",      "text": "    catch " },
        { "type": "plain",   "text": "{ /* rollback silencioso */ }" },
        { "type": "plain",   "text": "  };" },
        { "type": "plain",   "text": "  return { leads, updateLead };" },
        { "type": "plain",   "text": "};" }
      ]
    },
