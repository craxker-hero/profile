  {
    "id": "pixel-engine",
    "number": "02",
    "title": "PixelEngine",
    "tagline": "Game loop estable con ECS minimalista. Zero dependencias.",
    "why": "Quería demostrar que JS puro puede manejar un game loop eficiente sin frameworks. Implementé un Entity Component System desde cero y aprendí que el mayor enemigo del rendimiento es el GC, no la lógica del juego.",
    "emoji": "🎮",
    "image": null,
    "tags": [
      { "label": "Canvas API", "color": "yellow" },
      { "label": "JS Vanilla", "color": "green"  }
    ],
    "snippet": {
      "lang": "JavaScript",
      "lines": [
        { "type": "comment", "text": "// Game loop estable con delta time capeado" },
        { "type": "kw",      "text": "class " },
        { "type": "fn",      "text": "Engine" },
        { "type": "plain",   "text": " {" },
        { "type": "plain",   "text": "  #lastTime = 0;" },
        { "type": "plain",   "text": "" },
        { "type": "plain",   "text": "  #loop = (timestamp) => {" },
        { "type": "kw",      "text": "    const " },
        { "type": "plain",   "text": "dt = (timestamp - this.#lastTime) / " },
        { "type": "num",     "text": "1000" },
        { "type": "plain",   "text": ";" },
        { "type": "plain",   "text": "    this.#lastTime = timestamp;" },
        { "type": "comment", "text": "    // Cap a 16ms evita el 'spiral of death'" },
        { "type": "plain",   "text": "    this.update(Math.min(dt, " },
        { "type": "num",     "text": "0.016" },
        { "type": "plain",   "text": "));" },
        { "type": "plain",   "text": "    this.render();" },
        { "type": "plain",   "text": "    requestAnimationFrame(this.#loop);" },
        { "type": "plain",   "text": "  };" },
        { "type": "plain",   "text": "}" }
      ]
    },
    "metrics": [
      { "value": "60fps", "label": "Constante" },
      { "value": "12kb",  "label": "Bundle size" },
      { "value": "2.4k",  "label": "GitHub stars" }
    ],
    "url": "https://github.com/",
    "featured": true
  },
